generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Global settings for the app
model Settings {
  id               String  @id @default("global") // Single row pattern
  whatsappNumber   String  @default("1234567890")
  metaTitle        String  @default("Mystic Tarot | Tarot Consultations")
  metaDescription  String  @default("Experience profound spiritual clarity and guidance through our premium intuitive tarot readings.")
  updatedAt        DateTime @updatedAt
}

// Blog Posts
model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   // MD or HTML content
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tarot Cards definitions (for the free game & info)
model TarotCard {
  id          String   @id @default(uuid())
  cardId      String   @unique // e.g. "magician"
  name        String
  imageUrl    String
  description String
  updatedAt   DateTime @updatedAt
}

// Service Categories
model ConsultationCategory {
  id          String    @id @default(uuid())
  name        String
  description String?
  services    Service[]
  order       Int       @default(0)
  updatedAt   DateTime  @updatedAt
}

// Individual Services under categories
model Service {
  id           String               @id @default(uuid())
  title        String
  price        String
  duration     String
  description  String
  popular      Boolean              @default(false)
  categoryId   String
  category     ConsultationCategory @relation(fields: [categoryId], references: [id])
  order        Int                  @default(0)
  updatedAt    DateTime             @updatedAt
}
